{
    "$schema": "https://schema.railpack.com",
    "provider": "node",
    "packages": {
        "node": "20",
        "bun": "latest"
    },
    "buildAptPackages": [
        "openssl",
        "libssl3",
        "ca-certificates"
    ],
    "steps": {
        "build": {
            "commands": [
                "...",
                "bunx prisma generate",
                "bun run build"
            ]
        }
    },
    "deploy": {
        "aptPackages": [
            "openssl",
            "libssl3",
            "ca-certificates"
        ],
        "startCommand": "mkdir -p /app/data && bunx prisma db push --skip-generate && NODE_ENV=production HOSTNAME=0.0.0.0 PORT=3000 bun .next/standalone/server.js"
    }
}